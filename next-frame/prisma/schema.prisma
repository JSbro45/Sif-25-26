generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}


datasource db {
    provider = "postgresql"
}


enum Role {
  HOST
  USER
}

model User {
  id              Int      @id @default(autoincrement())
  role            Role?     @default(HOST)
  name            String
  email           String   @unique
  password        String    // For OAuth users
  verification    Boolean  @default(false) // User verification status
  events          Event[]  @relation("events")
  createdAt       DateTime @default(now())

  @@index([email])
}


model Event {
  id              Int @id @default(autoincrement())
  name            String
  description     String?
  date_time       DateTime
  photos          String[]
  genres          String[]
  createdAt       DateTime @default(now())
  latitude        Float
  longitude       Float
  hostUserId      Int 
  hostUser        User @relation("events", fields: [hostUserId], references: [id], onDelete: Cascade)
  //performers      String[]
  //addressId       Int?
  //address         Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@index([hostUserId])
  @@index([date_time])
  @@index([genres])
}

