generator client {
  provider = "prisma-client"
}


datasource db {
    provider = "postgresql"
}


model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  password        String    // For OAuth users
  verification    Boolean  @default(false) // User verification status
  //events          Event[]  
  createdAt       DateTime @default(now())

  @@index([email])
}


model Event {
  id              Int @id @default(autoincrement())
  name            String
  description     String?
  date_time       DateTime
  photos          String[]
  //hostUserId      Int 
  genres          String[]
  //hostUser        User @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  //performers      String[]
  createdAt       DateTime @default(now())
  latitude        Float
  longitude       Float
  //addressId       Int?
  //address         Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  //@@index([hostUserId])
}

model Address {
  id          Int      @id @default(autoincrement())
  placeName   String?
  postalCode  String?
  lat         Float  // latitude
  lng         Float  // longitude
  //events      Event[]

}
