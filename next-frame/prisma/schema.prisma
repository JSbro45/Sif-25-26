model Event {
  id              Int @id @default(autoincrement())
  name            String
  description     String?
  date_time       DateTime
  photos          String[]
  genres          String[]
  createdAt       DateTime @default(now())
  hostUserId      Int 
  hostUser        HostUserProfile @relation("events", fields: [hostUserId], references: [id], onDelete: Cascade)
  addressId       Int
  address         Address @relation("events", fields: [addressId], references: [id])

  @@index([hostUserId])
  @@index([date_time])
  @@index([genres])
}


model Address {
  id              Int      @id @default(autoincrement())
  region          String
  municipality    String
  district        String?
  street          String
  houseNumber     String
  postalCode      String
  lat             Float  // latitude
  lng             Float  // longitude
  events          Event[] @relation("events")

  @@index([id])
}
