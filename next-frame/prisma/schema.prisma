generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}


datasource db {
    provider = "postgresql"
}


model HostUserProfile {
  id            Int      @id @default(autoincrement())
  clerkId       String
  firstName     String
  lastName      String
  email         String   @unique
  password      String    // For OAuth users
  orgName       String?
  webSite       String?
  events        Event[]  @relation("events")
  baseAddressId Int?
  createdAt     DateTime @default(now())
  @@index([email])
}

